# --------------------------------------------------------------
# Supabase (storage for uploaded PDFs, extracted panels, audio, results)
# Free tier: https://supabase.com
# --------------------------------------------------------------
SUPABASE_URL=https://<your_project_id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>
SUPABASE_BUCKET_NAME=manhwa-content

# --------------------------------------------------------------
# AI PROVIDER — pick one: groq | google | openrouter
# Each has a free tier generous enough for this use case.
#   groq       → Groq cloud (llama-4-scout-17b-16e-instruct)
#   google     → Google AI Studio (Gemini 2.5 Flash)
#   openrouter → OpenRouter router (many free vision models)
# --------------------------------------------------------------
AI_PROVIDER=groq

# --------------------------------------------------------------
# Option A: Groq (free-tier LLM, vision-capable)
# Get keys: https://console.groq.com
# GROQ_API_KEYS (plural) = comma-separated list for key rotation
#   (multiplies your free-tier rate limit across multiple accounts)
# GROQ_API_KEY (singular) = single-key fallback
# --------------------------------------------------------------
GROQ_API_KEYS=gsk_key_one,gsk_key_two,gsk_key_three
# GROQ_API_KEY=gsk_single_key_here

# --------------------------------------------------------------
# Option B: Google AI Studio (Gemini 2.5 Flash — free tier)
# Get a key: https://aistudio.google.com/apikey
# --------------------------------------------------------------
# GOOGLE_API_KEY=your_google_api_key_here

# --------------------------------------------------------------
# Option C: OpenRouter (free vision model router)
# Get a key: https://openrouter.ai/keys
# Default model: google/gemini-2.5-flash-001 (free on OpenRouter)
# Override model: AI_MODEL=qwen/qwen2.5-vl-72b-instruct
# --------------------------------------------------------------
# OPENROUTER_API_KEY=your_openrouter_key_here
# AI_MODEL=google/gemini-2.5-flash-001

# --------------------------------------------------------------
# Celery broker + result backend (background job queue)
#
# LOCAL-ONLY USE: Celery just needs any broker; a single local Redis works
# fine for both roles (no RabbitMQ, no cloud account needed). If you're
# running `docker-compose up`, these two lines are already overridden to
# point at the bundled redis container — you can leave this file as-is.
# If running without Docker, install/run Redis locally (or
# `docker run -d -p 6379:6379 redis:alpine` as a one-off) and use:
RABBITMQ_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1
#
# ONLY IF DEPLOYING LIVE (skip for localhost): swap the two lines above for
# a hosted RabbitMQ (e.g. CloudAMQP free tier) and hosted Redis (e.g.
# Upstash free tier) so a public deployment isn't relying on your machine:
# RABBITMQ_URL=amqps://<user>:<password>@<host>/<vhost>
# REDIS_URL=redis://<user>:<password>@<host>:<port>

# --------------------------------------------------------------
# Misc
# --------------------------------------------------------------
DEBUG=True
